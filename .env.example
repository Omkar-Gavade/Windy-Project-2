# Copy to .env before deploying:   cp .env.example .env
#
# IMPORTANT — read this before hunting for missing credentials:
# This project currently reads NO environment variables in its Python code.
# There are no API keys, passwords, tokens or AWS credentials to supply.
# Plant details and pipeline settings live in config.py, and Windy access comes
# from the mounted windy_login.json session file — not from this file.
#
# The variables below are consumed by Docker/the container OS (not by the app
# code), so .env is still required by docker-compose.yml and is the right place
# to adjust deployment behaviour.


# --- Backend API -------------------------------------------------------------
# Base URL of the FastAPI backend that receives each generated clean MP4
# (POST /api/videos/upload). No trailing slash, no path. Required for uploads;
# if it is unset the recording still runs and only the upload step is skipped.
BACKEND_API_URL=http://13.206.205.164:8000


# --- Timezone -----------------------------------------------------------------
# IMPORTANT for correctness, not cosmetics. The forecast is split into 15-minute
# blocks derived from the container's local wall-clock time (datetime.now()).
# A fresh EC2 instance is UTC, which would shift every block for an India-based
# plant. Set this to the plant's actual timezone.
TZ=Asia/Kolkata


# --- Health probe tuning ------------------------------------------------------
# Max age (seconds) of the liveness heartbeat before the container is marked
# unhealthy. The loop refreshes /app/.heartbeat every ~60s (including while
# waiting for the next scheduled capture), so 300 = 5 min tolerates a slow
# capture cycle without false alarms. This is NOT tied to the capture schedule.
HEALTH_MAX_AGE_SECONDS=300
